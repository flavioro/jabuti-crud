APP_NAME=Jabuti Users API
APP_VERSION=0.5.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true
HOST=0.0.0.0
PORT=8000
RUN_MIGRATIONS_ON_STARTUP=false

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=jabuti_users
POSTGRES_USER=jabuti
POSTGRES_PASSWORD=jabuti
DATABASE_URL=postgresql+psycopg2://jabuti:jabuti@db:5432/jabuti_users

REDIS_URL=redis://cache:6379/0
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=120

CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:5173
